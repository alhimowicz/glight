{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "lib": ["ES2022"],
    "types": [
      "@girs/gjs",
      "@girs/gobject-2.0",
      "@girs/gio-2.0",
      "@girs/glib-2.0",
      "@girs/st-14",
      "@girs/clutter-14",
      "@girs/meta-14",
      "@girs/shell-0.1",
      "@girs/gtk-4.0",
      "@girs/adw-1"
    ],
    "paths": {
      "gi://Adw":            ["./node_modules/@girs/adw-1/adw-1.d.ts"],
      "gi://Adw?version=1":  ["./node_modules/@girs/adw-1/adw-1.d.ts"],
      "gi://GLib":           ["./node_modules/@girs/glib-2.0/glib-2.0.d.ts"],
      "gi://GObject":        ["./node_modules/@girs/gobject-2.0/gobject-2.0.d.ts"],
      "gi://Gio":            ["./node_modules/@girs/gio-2.0/gio-2.0.d.ts"],
      "gi://St":             ["./node_modules/@girs/st-14/st-14.d.ts"],
      "gi://Clutter":        ["./node_modules/@girs/clutter-14/clutter-14.d.ts"],
      "gi://Meta":           ["./node_modules/@girs/meta-14/meta-14.d.ts"],
      "gi://Shell":          ["./node_modules/@girs/shell-0.1/shell-0.1.d.ts"],
      "gi://Gtk":            ["./node_modules/@girs/gtk-4.0/gtk-4.0.d.ts"],
      "gi://Pango":          ["./node_modules/@girs/pango-1.0/pango-1.0.d.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
